# Plantilla de variables de entorno para FStats + Analizador de Viralidad.
# Copiá este archivo a `.env` (que está gitignoreado) y completá los valores.
# Nada de esto se sube al repo.

# ───────────────────────────── Warehouse (MotherDuck) ─────────────────────────
# Token de MotherDuck (base "fstats"). Necesario para leer/escribir el warehouse
# y para la realimentación (leer ig_posts, guardar análisis).
MOTHERDUCK_TOKEN=

# Desarrollo local sin nube: usar un archivo DuckDB local en vez de MotherDuck.
# FSTATS_DB_LOCAL=1
# FSTATS_DB_NAME=fstats

# ───────────────────────────── Meta / Instagram ──────────────────────────────
# Tokens del Graph API por portal. Necesarios para datos en vivo y para que la
# realimentación pueda bajar el mp4 de cada reel (media_url).

# Chubut Noticias
META_PAGE_ID=
META_INSTAGRAM_ID=
META_PAGE_ACCESS_TOKEN=

# Atento Chubut
META_PAGE_ID_ATENTO=
META_INSTAGRAM_ID_ATENTO=
META_PAGE_ACCESS_TOKEN_ATENTO=

# La Calle Online
META_PAGE_ID_LACALLE=
META_INSTAGRAM_ID_LACALLE=
META_PAGE_ACCESS_TOKEN_LACALLE=

# El Americano
META_PAGE_ID_AMERICANO=
META_INSTAGRAM_ID_AMERICANO=
META_PAGE_ACCESS_TOKEN_AMERICANO=

# VISTE ESTO? (solo Instagram)
META_INSTAGRAM_ID_VISTE=
META_PAGE_ACCESS_TOKEN_VISTE=

# Boca en Linea (solo Instagram)
META_INSTAGRAM_ID_BOCA=
META_PAGE_ACCESS_TOKEN_BOCA=

# ──────────────────────── Analizador de viralidad ────────────────────────────
# Motor de scoring:
#   heuristic (default) → reglas sobre features. Instantáneo, estable, sin deps.
#   model               → regresor entrenado con tus reels (data/analyzer/model.joblib).
#   ollama              → LLM de visión local (requiere >8 GB RAM o GPU; ver abajo).
ANALYZER_BACKEND=heuristic

# Solo si ANALYZER_BACKEND=ollama:
# OLLAMA_HOST=http://localhost:11434   # puede apuntar a otra máquina/servidor
# OLLAMA_MODEL=llava                   # alternativas: qwen2.5vl, llama3.2-vision
# OLLAMA_MAX_IMAGES=2                  # frames enviados al modelo (gancho)
# OLLAMA_NUM_CTX=4096                  # contexto del modelo
# OLLAMA_TIMEOUT=300                   # segundos antes de caer a heurístico
